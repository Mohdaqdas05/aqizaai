PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/aqizaai
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
SESSION_SECRET=your-session-secret-change-this
FRONTEND_URL=http://localhost:5173
# OpenRouter (routes requests to many AI providers)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Direct OpenAI API key (for direct-openai/* models)
OPENAI_API_KEY=your-openai-api-key
# Direct Google Gemini API key (for direct-gemini/* models)
GEMINI_API_KEY=your-gemini-api-key
ADMIN_EMAIL=admin@aqizaai.com
